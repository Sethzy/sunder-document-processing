# Browser-exposed Supabase client configuration.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Local development only: route uploaded files through the local Vercel function.
VITE_ENABLE_LOCAL_GEMINI_PROCESSING=false

# Server-side Supabase configuration for Vercel Functions.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-side AI provider credentials.
GEMINI_API_KEY=your-gemini-api-key
EXTEND_API_KEY=your-extend-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Shared secret for internal function-to-function calls.
SUNDER_INTERNAL_SECRET=replace-with-a-long-random-value

# Optional verbose server logs for local debugging. Leave false in production.
SUNDER_DEBUG_LOGS=false

# Optional WhatsApp/OpenClaw callback integration.
OPENCLAW_CALLBACK_URL=
WEBHOOK_SECRET=
